<% layout('layouts/patient_boilerplate') %>

    <div class="container d-flex flex-column align-items-center justify-content-center text-center my-5"
        style="min-height: 70vh;">

        <div class="mb-5 animate-fade-in">
            
            <h1 class="fw-bold text-dark display-5 mb-2">Patient Dashboard</h1>
            <p class="text-muted fs-5">Welcome back! Please choose an action from the options below.</p>
        </div>

        <div class="w-100 d-flex flex-column gap-3 justify-content-center align-items-center">

            <div class="col-10 col-sm-8 col-md-6 col-lg-5">
                <a href="/patient/new"
                    class="custom-btn btn btn-primary btn-lg rounded-pill shadow px-4 py-3 d-flex align-items-center justify-content-center gap-3">
                    <i class="bi bi-person-plus-fill fs-4"></i>
                    <span class="fw-semibold">Make an account?</span>
                </a>
            </div>

        </div>
        <a href="http:/patient/<%=patient._id %>">my account</a>
    </div>

    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .main-icon {
            width: 90px;
            height: 90px;
            background-color: #ffffff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #e9ecef;
        }

        .custom-btn {
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            border-width: 2px;
        }

        /* Primary Button Hover */
        .btn-primary.custom-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(13, 110, 253, 0.3) !important;
        }

        /* Outline Button Hover */
        .btn-outline-primary.custom-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(13, 110, 253, 0.15) !important;
            background-color: #0d6efd;
            color: #ffffff;
        }

        /* Simple Fade-in Animation */
        .animate-fade-in {
            animation: fadeIn 0.6s ease-out forwards;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>