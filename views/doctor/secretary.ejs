<% layout('layouts/doctor_boilerplate') %>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <div class="mb-4">
                    <a href="/doctor/secretaries"
                        class="btn btn-sm btn-outline-primary rounded-pill px-4 fw-semibold shadow-sm">
                        <i class="bi bi-arrow-left me-1"></i> Back to List
                    </a>
                </div>

                <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                    <div class="bg-primary bg-gradient text-white text-center py-5 px-3 position-relative">
                        <h3 class="fw-bold mb-2">
                            <%= secretary.name %>
                        </h3>
                        <span class="badge bg-white text-primary px-4 py-2 rounded-pill fw-bold shadow-sm"
                            style="letter-spacing: 0.5px;">
                            Medical Secretary
                        </span>
                    </div>

                    <div class="card-body p-4 p-md-5 bg-white">

                        <h6
                            class="fw-bold text-primary mb-3 text-uppercase border-bottom border-primary border-opacity-10 pb-2">
                            <i class="bi bi-person-lines-fill me-2"></i>Contact Information
                        </h6>

                        <div
                            class="d-flex align-items-center mb-3 p-3 bg-white border border-primary border-opacity-10 rounded-3 shadow-sm">
                            <div class="d-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle me-3"
                                style="width: 45px; height: 45px;">
                                <i class="bi bi-envelope-fill fs-5"></i>
                            </div>
                            <div>
                                <small class="text-primary text-opacity-75 fw-semibold d-block lh-1 mb-1">Email
                                    Address</small>
                                <span class="fw-bold text-dark">
                                    <%= secretary.email %>
                                </span>
                            </div>
                        </div>

                        <div
                            class="d-flex align-items-center mb-5 p-3 bg-white border border-primary border-opacity-10 rounded-3 shadow-sm">
                            <div class="d-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle me-3"
                                style="width: 45px; height: 45px;">
                                <i class="bi bi-telephone-fill fs-5"></i>
                            </div>
                            <div>
                                <small class="text-primary text-opacity-75 fw-semibold d-block lh-1 mb-1">Phone
                                    Number</small>
                                <span class="fw-bold text-dark">
                                    <%= secretary.phone %>
                                </span>
                            </div>
                        </div>

                        <h6
                            class="fw-bold text-primary mb-3 text-uppercase border-bottom border-primary border-opacity-10 pb-2">
                            <i class="bi bi-briefcase-fill me-2"></i>Assignments
                        </h6>

                        <div
                            class="d-flex align-items-center mb-3 p-3 bg-white border border-primary border-opacity-10 rounded-3 shadow-sm">
                            <div class="d-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle me-3"
                                style="width: 45px; height: 45px;">
                                <i class="bi bi-hospital-fill fs-5"></i>
                            </div>
                            <div>
                                <small class="text-primary text-opacity-75 fw-semibold d-block lh-1 mb-1">Assigned
                                    Clinic</small>
                                <span class="fw-bold text-dark">
                                    <%= secretary.clinic ? secretary.clinic.name : 'Not Assigned' %>
                                </span>
                            </div>
                        </div>

                        <div
                            class="d-flex align-items-center p-3 bg-white border border-primary border-opacity-10 rounded-3 shadow-sm">
                            <div class="d-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle me-3"
                                style="width: 45px; height: 45px;">
                                <i class="bi bi-heart-pulse-fill fs-5"></i>
                            </div>
                            <div>
                                <small class="text-primary text-opacity-75 fw-semibold d-block lh-1 mb-1">Assigned
                                    Doctor</small>
                                <span class="fw-bold text-dark">
                                    Dr. <%= secretary.doctor ? secretary.doctor.name : 'Not Assigned' %>
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-white border-top-0 p-4 pt-0 d-flex gap-2">
                        <a href="/doctor/secretary/<%=secretary._id%>/edit"
                            class="btn btn-primary bg-gradient flex-grow-1 py-2 rounded-3 text-white fw-semibold shadow-sm d-flex justify-content-center align-items-center">
                            <span><i class="bi bi-pencil-square me-1"></i> Edit Profile</span>
                        </a>
                        
                        <form action="/secretary/<%=secretary._id%>?_method=DELETE" method="POST" class="m-0"
                            onsubmit="return confirm('Are you sure you want to delete this secretary? This action cannot be undone.');">
                            <button type="submit" class="btn btn-outline-danger px-4 h-100 rounded-3 shadow-sm d-flex justify-content-center align-items-center" title="Delete Secretary">
                                <i class="bi bi-trash3-fill">delete secretary</i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>