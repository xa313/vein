<% layout('layouts/doctor_boilerplate') %>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <div class="mb-4">
                    <a href="/doctor/secretary/<%=secretary._id%>" class="btn btn-sm btn-outline-primary rounded-pill px-4 fw-semibold shadow-sm">
                        <i class="bi bi-arrow-left me-1"></i> Back to List
                    </a>
                </div>

                <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                    <div class="bg-primary bg-gradient text-white text-center py-4 px-3 position-relative">
                        <h4 class="fw-bold mb-1">Edit Profile</h4>
                        <p class="text-white-50 mb-0 small">Update secretary details and contact info</p>
                    </div>

                    <form action="/secretary/<%=secretary._id%>?_method=PUT" method="POST" class="needs-validation" novalidate> 
                        
                        <div class="card-body p-4 p-md-5 bg-white">
                            <h6 class="fw-bold text-primary mb-4 text-uppercase border-bottom border-primary border-opacity-10 pb-2">
                                <i class="bi bi-person-lines-fill me-2"></i>Personal Information
                            </h6>

                            <div class="mb-4">
                                <label for="name" class="form-label fw-semibold text-dark small mb-1">Full Name</label>
                                <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden border border-primary border-opacity-10">
                                    <span class="input-group-text bg-primary bg-opacity-10 border-0 text-primary px-3">
                                        <i class="bi bi-person-fill fs-5"></i>
                                    </span>
                                    <input type="text" id="name" name="secretary[name]" class="form-control border-0 bg-light" value="<%= secretary.name %>" placeholder="Enter full name" required>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label for="email" class="form-label fw-semibold text-dark small mb-1">Email Address</label>
                                <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden border border-primary border-opacity-10">
                                    <span class="input-group-text bg-primary bg-opacity-10 border-0 text-primary px-3">
                                        <i class="bi bi-envelope-fill fs-5"></i>
                                    </span>
                                    <input type="email" id="email" name="secretary[email]" class="form-control border-0 bg-light" value="<%= secretary.email %>" placeholder="name@example.com" required>
                                </div>
                            </div>

                            <div class="mb-5">
                                <label for="phone" class="form-label fw-semibold text-dark small mb-1">Phone Number</label>
                                <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden border border-primary border-opacity-10">
                                    <span class="input-group-text bg-primary bg-opacity-10 border-0 text-primary px-3">
                                        <i class="bi bi-telephone-fill fs-5"></i>
                                    </span>
                                    <input type="text" id="phone" name="secretary[phone]" class="form-control border-0 bg-light" value="<%= secretary.phone %>" placeholder="Enter phone number" required>
                                </div>
                            </div>

                        </div>

                        <div class="card-footer bg-white border-top-0 p-4 pt-0 d-flex gap-3">
                            <a href="/doctor/secretaries" class="btn btn-light text-secondary fw-bold py-2 px-4 rounded-3 shadow-sm border border-secondary border-opacity-25">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-primary bg-gradient flex-grow-1 py-2 rounded-3 text-white fw-bold shadow-sm">
                                <i class="bi bi-check-circle-fill me-1"></i> Save Changes
                            </button>
                        </div>

                    </form>
                </div>

            </div>
        </div>
    </div>