<% layout('layouts/doctor_boilerplate') %>
    <div class="container mt-4">
        <h1 class="mb-4 text-center">Add Secretary Page</h1>
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <form action="/secretary" method="POST" class="needs-validation" novalidate>
                    <!-- الاسم -->
                    <div class="mb-3">
                        <label for="name" class="form-label">Full Name</label>
                        <input type="text" class="form-control" id="name" name="secretary[name]"
                            placeholder="Enter full name">
                    </div>
                    <!-- رقم الهاتف -->
                    <div class="mb-3">
                        <label for="phone" class="form-label">Phone Number</label>
                        <input type="number" class="form-control" id="phone" name="secretary[phone]"
                            placeholder="Enter phone number">
                    </div>

                    <!-- البريد الإلكتروني -->
                    <div class="mb-3">
                        <label for="email" class="form-label">Email Address *</label>
                        <input type="email" class="form-control" id="email" name="secretary[email]"
                            placeholder="name@example.com" required>
                        <div class="invalid-feedback">
                            Please provide a valid and unique email address.
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a href="/doctor" class="btn btn-secondary me-md-2">Cancel</a>
                        <button type="submit" class="btn btn-primary">Add Secretary</button>
                    </div>
                </form>
            </div>
        </div>
    </div>