<% layout('layouts/doctor_boilerplate') %>
    <div class="container py-5">
        <div class="row justify-content-center mb-5">
            <div class="col-md-8 text-center">
                <h1 class="display-5 fw-bold text-primary mb-2">Doctor Dashboard</h1>
                <p class="text-muted fs-5">Manage your medical practice with ease</p>
                <div class="bg-primary mx-auto" style="width: 60px; height: 3px; border-radius: 2px;"></div>
            </div>
        </div>
        <div class="row justify-content-center g-4">
            <div class="col-sm-6 col-md-4 col-lg-3">
                <a href="/doctor/secretaries" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm p-4 rounded-4 hover-lift text-center transition-all">
                        <div class="fs-1 text-primary mb-3"><i class="bi bi-people-fill"></i></div>
                        <h5 class="fw-bold text-dark">Secretaries</h5>
                        <p class="text-muted small mb-0">Manage clinic staff</p>
                    </div>
                </a>
            </div>

            <div class="col-sm-6 col-md-4 col-lg-3">
                <a href="/doctor/patients" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm p-4 rounded-4 hover-lift text-center transition-all">
                        <div class="fs-1 text-success mb-3"><i class="bi bi-person-lines-fill"></i></div>
                        <h5 class="fw-bold text-dark">Patients</h5>
                        <p class="text-muted small mb-0">View patient records</p>
                    </div>
                </a>
            </div>
            <div class="col-sm-6 col-md-4 col-lg-3">
                <a href="/" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm p-4 rounded-4 hover-lift text-center transition-all">
                        <div class="fs-1 text-info mb-3"><i class="bi bi-calendar-check-fill"></i></div>
                        <h5 class="fw-bold text-dark">Appointments</h5>
                        <p class="text-muted small mb-0">Manage clinic schedule</p>
                    </div>
                </a>
            </div>

        </div>
    </div>

    <style>
        .hover-lift {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .hover-lift:hover {
            transform: translateY(-10px);
            box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.1) !important;
        }

        .transition-all {
            transition: all 0.3s ease;
        }
    </style>