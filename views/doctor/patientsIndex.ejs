<% layout('layouts/doctor_boilerplate') %>

    <div class="container mt-5 mb-5">
        <!-- Page Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-1">Patient Registry</h2>
                <p class="text-muted mb-0">View and manage all registered patients</p>
            </div>
            <a href="/patient/new" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-lg"></i> Add New Patient
            </a>
        </div>

        <!-- Check if there are any patients -->
        <% if (patients.length===0) { %>
            <div class="alert alert-info text-center py-5 shadow-sm rounded-3" role="alert">
                <h4 class="alert-heading fw-bold">No Patients Found!</h4>
                <p class="mb-0 text-secondary">The database is currently empty. Start by adding your first patient.</p>
            </div>
            <% } else { %>

                <!-- Cards Grid -->
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    <% for(let patient of patients) { %>
                        <div class="col">
                            <div class="card h-100 patient-card shadow-sm border-0 transition-all">

                                <!-- Card Body -->
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <h5 class="card-title fw-bold text-truncate mb-0" style="max-width: 70%;">
                                            <%= patient.name %>
                                        </h5>
                                        <!-- Dynamic Gender Badge -->
                                        <% if(patient.gender==='male' ) { %>
                                            <span
                                                class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-3 py-1.5">Male</span>
                                            <% } else if(patient.gender==='female' ) { %>
                                                <span
                                                    class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-3 py-1.5">Female</span>
                                                <% } else { %>
                                                    <span
                                                        class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle rounded-pill px-3 py-1.5">LGBTQ+</span>
                                                    <% } %>
                                    </div>
                                    <hr class="text-muted opacity-25">
                                    <!-- Patient Details -->
                                    <div class="patient-details mb-4">
                                        <div class="d-flex align-items-center mb-2">
                                            <span class="text-secondary fw-semibold me-2"
                                                style="min-width: 60px;">Age:</span>
                                            <span class="text-dark">
                                                <%= patient.age %> years
                                            </span>
                                        </div>
                                        <div class="d-flex align-items-center">
                                            <span class="text-secondary fw-semibold me-2"
                                                style="min-width: 60px;">Phone:</span>
                                            <span class="text-dark font-monospace">
                                                <%= patient.phone ? patient.phone : 'Not Registered' %>
                                            </span>
                                        </div>
                                    </div>

                                    <!-- View Details Button -->
                                    <div class="d-grid">
                                        <a href="/doctor/patient/<%=patient._id %>"
                                            class="btn btn-outline-primary btn-detail rounded-pill fw-semibold shadow-sm">
                                            View Details
                                        </a>
                                    </div>
                                </div>

                            </div>
                        </div>
                        <% } %>
                </div>

                <% } %>
    </div>

    <!-- Custom Style Rules -->
    <style>
        body {
            background-color: #f8f9fa;
        }

        .patient-card {
            border-radius: 1.2rem;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            background: #ffffff;
        }

        .patient-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08) !important;
        }

        .btn-detail {
            transition: all 0.2s ease;
        }

        .btn-detail:hover {
            background-color: #0d6efd;
            color: #fff;
        }
    </style>