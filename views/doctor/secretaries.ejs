<% layout('layouts/doctor_boilerplate') %>
    <div class="container mt-4">
        <!-- الهيدر الرئيسي مع زر الإضافة -->
        <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
            <h1 class="mb-0 fw-bold text-secondary">Secretaries Page</h1>
            <!-- زر إضافة سكرتير -->
            <a href="/doctor/secretary/new" class="btn btn-success d-flex align-items-center gap-2 px-4 py-2 rounded-pill shadow-sm">
                <i class="bi bi-person-plus-fill"></i> Add New Secretary
            </a>
        </div>
        <div class="row">
            <% for(let secretary of secretaries) { %>
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 rounded-3">
                        <div class="card-body d-flex flex-column p-4">
                            <!-- Secretary Name -->
                            <h5 class="card-title fw-bold text-primary mb-3">
                                <%= secretary.name %>
                            </h5>
                            <!-- Phone Number -->
                            <p class="card-text mb-2 text-muted">
                                <strong class="text-dark">Phone:</strong>
                                <%= secretary.phone %>
                            </p>
                            <!-- Clinic Name -->
                            <p class="card-text mb-4 text-muted">
                                <strong class="text-dark">Clinic:</strong>
                                <%= secretary.clinic.name %>
                            </p>
                            <!-- Details Button -->
                            <a href="/doctor/secretary/<%=secretary._id %>" class="btn btn-outline-primary w-100 mt-auto rounded-3">View Details</a>
                        </div>
                    </div>
                </div>
                <% } %>
        </div>
    </div>