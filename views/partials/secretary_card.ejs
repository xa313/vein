<div class="card shadow-lg border-0 rounded-4 overflow-hidden profile-card">

    <div class="bg-primary bg-gradient text-white text-center py-5 px-3 position-relative">

        <div id="display-sec-name" class="cursor-pointer inline-hover rounded p-2 d-inline-block mb-2 w-100"
            onclick="toggleInlineEdit('sec-name')" title="Click to edit Name">
            <h3 class="fw-bold mb-0 text-truncate d-flex justify-content-center align-items-center gap-2">
                <%= secretary.name %> <i class="bi bi-pencil-fill fs-6 opacity-75"></i>
            </h3>
        </div>

        <div id="edit-sec-name" class="d-none w-100 mb-3">
            <form class="d-flex flex-column align-items-center justify-content-center gap-2 w-100"
                action="/secretary/<%=secretary._id%>?_method=PUT" method="POST" onclick="event.stopPropagation()">
                <input type="text" class="form-control text-center fw-bold text-primary shadow-sm mx-auto"
                    style="max-width: 300px;" name="secretary[name]" value="<%= secretary.name %>" required autofocus>
                <div class="d-flex gap-2 justify-content-center mt-2">
                    <button type="submit" class="btn btn-success btn-sm px-4 fw-bold shadow-sm">Update</button>
                    <button type="button" class="btn btn-secondary btn-sm px-4 fw-bold shadow-sm"
                        onclick="toggleInlineEdit('sec-name')">Cancel</button>
                </div>
            </form>
        </div>

        <span class="badge bg-white text-primary px-4 py-2 rounded-pill fw-bold shadow-sm"
            style="letter-spacing: 0.5px;">
            Medical Secretary
        </span>
    </div>

    <div class="card-body p-4 p-md-5 bg-white">

        <h6 class="fw-bold text-primary mb-3 text-uppercase border-bottom border-primary border-opacity-10 pb-2">
            <i class="bi bi-person-lines-fill me-2"></i>Contact Information
        </h6>

        <div class="position-relative cursor-pointer field-hover mb-3 p-3 bg-white border border-primary border-opacity-10 rounded-3 shadow-sm"
            onclick="toggleInlineEdit('sec-email')" title="Click to edit Email">

            <div id="display-sec-email" class="d-flex align-items-center w-100">
                <div class="d-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle me-3"
                    style="width: 45px; height: 45px;">
                    <i class="bi bi-envelope-fill fs-5"></i>
                </div>
                <div class="flex-grow-1">
                    <small class="text-primary text-opacity-75 fw-semibold d-block lh-1 mb-1">Email Address</small>
                    <span class="fw-bold text-dark">
                        <%= secretary.email %>
                    </span>
                </div>
                <i class="bi bi-pencil-square me-2 text-secondary opacity-50"></i>
            </div>

            <div id="edit-sec-email" class="d-none mt-2 w-100">
                <form class="d-flex flex-column gap-2" action="/secretary/<%=secretary._id%>?_method=PUT" method="POST"
                    onclick="event.stopPropagation()">
                    <div class="input-group input-group-sm shadow-sm rounded-3 overflow-hidden">
                        <span class="input-group-text bg-primary bg-opacity-10 border-0 text-primary"><i
                                class="bi bi-envelope-fill"></i></span>
                        <input type="email" class="form-control border-0 bg-light" name="secretary[email]"
                            value="<%= secretary.email %>" placeholder="name@example.com" required>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success btn-sm px-3 fw-bold flex-grow-1">Update</button>
                        <button type="button" class="btn btn-secondary btn-sm px-3 fw-bold flex-grow-1"
                            onclick="toggleInlineEdit('sec-email')">Cancel</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="position-relative cursor-pointer field-hover mb-5 p-3 bg-white border border-primary border-opacity-10 rounded-3 shadow-sm"
            onclick="toggleInlineEdit('sec-phone')" title="Click to edit Phone">

            <div id="display-sec-phone" class="d-flex align-items-center w-100">
                <div class="d-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle me-3"
                    style="width: 45px; height: 45px;">
                    <i class="bi bi-telephone-fill fs-5"></i>
                </div>
                <div class="flex-grow-1">
                    <small class="text-primary text-opacity-75 fw-semibold d-block lh-1 mb-1">Phone Number</small>
                    <span class="fw-bold text-dark">
                        <%= secretary.phone %>
                    </span>
                </div>
                <i class="bi bi-pencil-square me-2 text-secondary opacity-50"></i>
            </div>

            <div id="edit-sec-phone" class="d-none mt-2 w-100">
                <form class="d-flex flex-column gap-2" action="/secretary/<%=secretary._id%>?_method=PUT" method="POST"
                    onclick="event.stopPropagation()">
                    <div class="input-group input-group-sm shadow-sm rounded-3 overflow-hidden">
                        <span class="input-group-text bg-primary bg-opacity-10 border-0 text-primary"><i
                                class="bi bi-telephone-fill"></i></span>
                        <input type="text" class="form-control border-0 bg-light" name="secretary[phone]"
                            value="<%= secretary.phone %>" placeholder="Enter phone number" required>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success btn-sm px-3 fw-bold flex-grow-1">Update</button>
                        <button type="button" class="btn btn-secondary btn-sm px-3 fw-bold flex-grow-1"
                            onclick="toggleInlineEdit('sec-phone')">Cancel</button>
                    </div>
                </form>
            </div>
        </div>

        <h6 class="fw-bold text-primary mb-3 text-uppercase border-bottom border-primary border-opacity-10 pb-2">
            <i class="bi bi-briefcase-fill me-2"></i>Assignments
        </h6>

        <div
            class="d-flex align-items-center mb-3 p-3 bg-white border border-primary border-opacity-10 rounded-3 shadow-sm">
            <div class="d-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle me-3"
                style="width: 45px; height: 45px;">
                <i class="bi bi-hospital-fill fs-5"></i>
            </div>
            <div>
                <small class="text-primary text-opacity-75 fw-semibold d-block lh-1 mb-1">Assigned Clinic</small>
                <span class="fw-bold text-dark">
                    <%= secretary.clinic ? secretary.clinic.name : 'Not Assigned' %>
                </span>
            </div>
        </div>

        <div class="d-flex align-items-center p-3 bg-white border border-primary border-opacity-10 rounded-3 shadow-sm">
            <div class="d-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle me-3"
                style="width: 45px; height: 45px;">
                <i class="bi bi-heart-pulse-fill fs-5"></i>
            </div>
            <div>
                <small class="text-primary text-opacity-75 fw-semibold d-block lh-1 mb-1">Assigned Doctor</small>
                <span class="fw-bold text-dark">
                    Dr. <%= secretary.doctor ? secretary.doctor.name : 'Not Assigned' %>
                </span>
            </div>
        </div>
    </div>

    <div class="card-footer bg-light border-top-0 p-4 d-flex">
        <form action="/secretary/<%=secretary._id%>?_method=DELETE" method="POST" class="w-100 m-0"
            onsubmit="return confirm('Are you sure you want to delete this secretary? This action cannot be undone.');">
            <button type="submit"
                class="btn btn-outline-danger w-100 py-2 rounded-3 shadow-sm fw-bold d-flex justify-content-center align-items-center gap-2"
                title="Delete Secretary">
                <i class="bi bi-trash3-fill"></i> Delete Secretary Account
            </button>
        </form>
    </div>
</div>

<script>
    function toggleInlineEdit(field) {
        const displayDiv = document.getElementById(`display-${field}`);
        const editFormWrapper = document.getElementById(`edit-${field}`);

        document.querySelectorAll('div[id^="edit-"]:not(.d-none)').forEach(wrapper => {
            if (wrapper.id !== `edit-${field}`) {
                wrapper.classList.add('d-none');
                document.getElementById(`display-${wrapper.id.replace('edit-', '')}`).classList.remove('d-none');
            }
        });

        displayDiv.classList.toggle('d-none');
        editFormWrapper.classList.toggle('d-none');
    }
</script>

<style>
    .cursor-pointer {
        cursor: pointer;
    }

    .inline-hover:hover {
        background-color: rgba(255, 255, 255, 0.15);
        transition: 0.3s ease;
    }

    .field-hover:hover {
        background-color: #f8f9fa !important;
        transition: 0.3s ease;
        box-shadow: 0 .5rem 1rem rgba(0, 0, 0, .08) !important;
        transform: translateY(-2px);
    }

    .field-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
    }
</style>