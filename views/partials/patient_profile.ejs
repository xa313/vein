<div class="mb-3">
    <a href="<%= backUrl %>" class="btn btn-link text-decoration-none text-secondary p-0">
        <i class="bi bi-arrow-left"></i> <%= backText %>
    </a>
</div>

<div class="card profile-card shadow-lg border-0 overflow-hidden">
    
    <div class="profile-header text-white text-center py-4 px-3 position-relative">
        
        <div id="display-name" class="cursor-pointer inline-hover rounded p-2 d-inline-block" onclick="toggleInlineEdit('name')" title="Click to edit name">
            <h3 class="fw-bold mb-0 text-truncate">
                <%= patient.name %> <i class="bi bi-pencil-fill fs-6 ms-2 opacity-50"></i>
            </h3>
        </div>
        <form id="edit-name" class="d-none mt-2" action="/patient/<%= patient._id %>?_method=PUT" method="POST" onclick="event.stopPropagation()" onsubmit="return confirm('Are you sure you want to update the Name to:\n' + this.elements['patient[name]'].value)">
            <input type="text" class="form-control text-center fw-bold mb-2" name="patient[name]" value="<%= patient.name %>" required autofocus>
            <div class="d-flex justify-content-center gap-2">
                <button type="submit" class="btn btn-success btn-sm fw-bold"><i class="bi bi-check-lg"></i> Update</button>
                <button type="button" class="btn btn-light btn-sm fw-bold" onclick="toggleInlineEdit('name')"><i class="bi bi-x-lg"></i> Cancel</button>
            </div>
        </form>

        <div class="w-100"></div>

        <div id="display-gender" class="cursor-pointer inline-hover rounded p-1 mt-2 d-inline-block" onclick="toggleInlineEdit('gender')" title="Click to edit gender">
            <% if(patient.gender==='male' ) { %>
                <span class="badge bg-white text-primary rounded-pill px-3 py-1.5 fw-semibold shadow-sm">Male <i class="bi bi-pencil-fill ms-1 opacity-50"></i></span>
            <% } else if(patient.gender==='female' ) { %>
                <span class="badge bg-white text-danger rounded-pill px-3 py-1.5 fw-semibold shadow-sm">Female <i class="bi bi-pencil-fill ms-1 opacity-50"></i></span>
            <% } else { %>
                <span class="badge bg-white text-warning-emphasis rounded-pill px-3 py-1.5 fw-semibold shadow-sm">LGBTQ+ <i class="bi bi-pencil-fill ms-1 opacity-50"></i></span>
            <% } %>
        </div>
        <form id="edit-gender" class="d-none mt-2" action="/patient/<%= patient._id %>?_method=PUT" method="POST" onclick="event.stopPropagation()" onsubmit="return confirm('Are you sure you want to update the Gender to:\n' + this.elements['patient[gender]'].value)">
            <select class="form-select mb-2 text-center" name="patient[gender]" required>
                <option value="male" <%=patient.gender==='male' ? 'selected' : '' %>>Male</option>
                <option value="female" <%=patient.gender==='female' ? 'selected' : '' %>>Female</option>
                <option value="LGBTQ+" <%=patient.gender==='LGBTQ+' ? 'selected' : '' %>>LGBTQ+</option>
            </select>
            <div class="d-flex justify-content-center gap-2">
                <button type="submit" class="btn btn-success btn-sm fw-bold"><i class="bi bi-check-lg"></i> Update</button>
                <button type="button" class="btn btn-light btn-sm fw-bold" onclick="toggleInlineEdit('gender')"><i class="bi bi-x-lg"></i> Cancel</button>
            </div>
        </form>

    </div>

    <div class="card-body p-4 p-md-5 bg-white">
        <h5 class="fw-bold text-dark mb-4 border-bottom pb-2">Medical Profile Information</h5>

        <div class="row g-4 mb-5">
            <div class="col-6">
                <div class="p-3 bg-light rounded-3 h-100 position-relative cursor-pointer field-hover" onclick="toggleInlineEdit('age')" title="Click to edit age">
                    <small class="text-muted d-block mb-1 text-uppercase fw-semibold tracking-wider">Age</small>
                    
                    <div id="display-age">
                        <span class="fs-5 fw-bold text-dark"><%= patient.age %></span> <span class="fs-6 fw-normal text-secondary">years</span>
                        <i class="bi bi-pencil-square position-absolute top-0 end-0 m-3 text-secondary opacity-50"></i>
                    </div>

                    <form id="edit-age" class="d-none mt-2" action="/patient/<%= patient._id %>?_method=PUT" method="POST" onclick="event.stopPropagation()" onsubmit="return confirm('Are you sure you want to update the Age to:\n' + this.elements['patient[age]'].value + ' years?')">
                        <input type="number" class="form-control mb-2 text-center" name="patient[age]" value="<%= patient.age %>" min="0" max="150" required autofocus>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success btn-sm flex-grow-1 fw-bold"><i class="bi bi-check-lg"></i> Update</button>
                            <button type="button" class="btn btn-secondary btn-sm flex-grow-1 fw-bold" onclick="toggleInlineEdit('age')"><i class="bi bi-x-lg"></i> Cancel</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col-6">
                <div class="p-3 bg-light rounded-3 h-100 position-relative cursor-pointer field-hover" onclick="toggleInlineEdit('phone')" title="Click to edit phone">
                    <small class="text-muted d-block mb-1 text-uppercase fw-semibold tracking-wider">Phone Number</small>
                    
                    <div id="display-phone">
                        <span class="fs-5 fw-bold text-dark font-monospace" dir="ltr"><%= patient.phone ? patient.phone : 'N/A' %></span>
                        <i class="bi bi-pencil-square position-absolute top-0 end-0 m-3 text-secondary opacity-50"></i>
                    </div>

                    <form id="edit-phone" class="d-none mt-2" action="/patient/<%= patient._id %>?_method=PUT" method="POST" onclick="event.stopPropagation()" onsubmit="return confirm('Are you sure you want to update the Phone Number to:\n' + this.elements['patient[phone]'].value)">
                        
                        <input type="text" dir="ltr" class="form-control mb-2 text-center font-monospace" name="patient[phone]" value="<%= patient.phone %>" 
                               pattern="^\+?[0-9]+$" 
                               title="Phone number must contain only digits, and optionally start with +"
                               oninput="this.value = this.value.replace(/[^0-9+]/g, '').replace(/(?!^)\+/g, '');"
                               required autofocus>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success btn-sm flex-grow-1 fw-bold"><i class="bi bi-check-lg"></i> Update</button>
                            <button type="button" class="btn btn-secondary btn-sm flex-grow-1 fw-bold" onclick="toggleInlineEdit('phone')"><i class="bi bi-x-lg"></i> Cancel</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-center pt-2 border-top">
            <form action="/patient/<%= patient._id %>?_method=DELETE" method="POST" class="w-50"
                onsubmit="return confirm('Are you sure you want to delete this patient permanently?');">
                <button type="submit" class="btn btn-danger w-100 py-2.5 rounded-pill fw-semibold shadow-sm">
                    <i class="bi bi-trash3 me-1"></i> Delete Patient
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    function toggleInlineEdit(field) {
        const displayDiv = document.getElementById(`display-${field}`);
        const editForm = document.getElementById(`edit-${field}`);
        
        displayDiv.classList.toggle('d-none');
        editForm.classList.toggle('d-none');
    }
</script>

<style>
    body { background-color: #f8f9fa; }
    .profile-card { border-radius: 1.5rem; }
    .profile-header { background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%); }
    .cursor-pointer { cursor: pointer; }
    .inline-hover:hover { background-color: rgba(255, 255, 255, 0.1); transition: 0.3s; }
    .field-hover:hover { background-color: #e9ecef !important; transition: 0.3s; box-shadow: inset 0 0 10px rgba(0,0,0,0.05); }
    .tracking-wider { letter-spacing: 0.5px; font-size: 0.75rem; }
</style>